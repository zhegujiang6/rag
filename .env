# ============================================================
# 应用基础配置
# ============================================================
APP_NAME=智能文档检索助手       # 应用名称
APP_VERSION=0.1.0              # 应用版本号
DEBUG=false                    # 调试模式（true=开启调试，false=生产模式）
API_PREFIX=/api/v1             # API 路由前缀


# ============================================================
# 数据库配置（MySQL）
# ============================================================
DB_HOST=127.0.0.1              # 数据库主机地址（localhost 或 IP）
DB_PORT=3306                   # 数据库端口（MySQL 默认 3306）
DB_USER=root                   # 数据库用户名
DB_PASSWORD=123456             # 数据库密码
DB_NAME=doc_search             # 数据库名称

# 完整数据库连接 URL（可选，优先使用此配置）
# 如果设置了 DATABASE_URL，将忽略上面的独立配置项
DATABASE_URL=mysql+asyncmy://root:123456@127.0.0.1:3306/doc_search


# ============================================================
# 大语言模型（LLM）配置
# ============================================================
# 阿里云通义千问 API Key（在阿里云控制台获取）
LLM_API_KEY=sk-ws-H.RYYILME.2Mwn.MEUCIAbBqv6OC9n6-cbSpA6IO4MUTf1k8SUEhT41ZHd7cx7CAiEAlwW-q6iYGrY3sXAnUXhHYrTgL455D9Qv3Cv1gS7jkkY
LLM_API_BASE=https://ws-0mw9t4zzmzspb2xr.cn-beijing.maas.aliyuncs.com/compatible-mode/v1  # API 基础地址
LLM_MODEL=qwen-plus-2025-07-28             # 模型名称（qwen-turbo, qwen-max, qwen-plus 等）
LLM_TEMPERATURE=0.7            # 温度参数（0=确定性高，1=随机性高）
LLM_MAX_TOKENS=2048            # 最大生成 token 数


# ============================================================
# Embedding（文本向量）配置
# ============================================================
# 阿里云通义 Embedding API Key（通常与 LLM API Key 相同）
EMBEDDING_API_KEY=sk-ws-H.RYYILME.2Mwn.MEUCIAbBqv6OC9n6-cbSpA6IO4MUTf1k8SUEhT41ZHd7cx7CAiEAlwW-q6iYGrY3sXAnUXhHYrTgL455D9Qv3Cv1gS7jkkY
EMBEDDING_API_BASE=https://ws-0mw9t4zzmzspb2xr.cn-beijing.maas.aliyuncs.com/compatible-mode/v1  # API 基础地址
EMBEDDING_MODEL=text-embedding-v4  # Embedding 模型名称
EMBEDDING_DIMENSION=1024       # 向量维度（需与模型匹配）
MULTIMODAL_EMBEDDING_ENABLED=true
MULTIMODAL_EMBEDDING_MODEL=qwen3-vl-embedding
MULTIMODAL_EMBEDDING_DIMENSION=1024
VISION_PARSING_ENABLED=true
VISION_MODEL=qwen3.5-omni-plus-2026-03-15
VISION_MAX_TOKENS=1500


# ============================================================
# ChromaDB 向量数据库配置
# ============================================================
CHROMA_PERSIST_DIR=./data/chroma  # 向量数据持久化存储目录


# ============================================================
# 文件存储配置
# ============================================================
UPLOAD_DIR=./data/uploads      # 上传文件存储目录
MAX_FILE_SIZE=52428800         # 最大文件大小（50MB = 50 * 1024 * 1024）


# ============================================================
# 文档分割配置（RAG 核心参数）
# ============================================================
SUB_CHUNK_SIZE=256             # 子块大小（tokens），用于向量检索
PARENT_CHUNK_SIZE=1024         # 父块大小（tokens），用于 LLM 上下文
CHUNK_OVERLAP=50               # 块之间的重叠大小（tokens），保持上下文连续性
SUB_CHUNKS_PER_PARENT=4        # 每个父块包含的子块数量


# ============================================================
# 检索配置
# ============================================================
RETRIEVAL_TOP_K=5              # 语义检索返回的结果数量
SIMILARITY_THRESHOLD=0.5       # 相似度阈值（低于此值的结果会被过滤）

# ============================================================
# RAGAS 优化开关（全部关闭 = 纯语义检索基线）
# ============================================================
HYBRID_SEARCH_ENABLED=true
RERANK_ENABLED=true
QUERY_REWRITE_ENABLED=true
CONTEXT_COMPRESSION_ENABLED=true
SEMANTIC_CHUNKING_ENABLED=true
EVALUATION_ENABLED=true
RETRIEVAL_MULTIPLIER=3


# ============================================================
# 认证配置（当前版本未使用）
# ============================================================
JWT_SECRET=change-me-in-production  # JWT 密钥（生产环境需修改）
JWT_ALGORITHM=HS256            # JWT 加密算法
JWT_EXPIRE_MINUTES=1440        # JWT 过期时间（分钟）


# ============================================================
# CORS 跨域配置（当前版本未使用）
# ============================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000  # 允许的跨域来源
